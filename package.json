{
  "name": "monstera-pdf-editor",
  "version": "1.3.6",
  "description": "Monstera PDF Editor — a desktop PDF editor by Tenslor Inc.",
  "main": "dist-electron/main/main.js",
  "author": "Tenslor Inc.",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "npm run build:electron && wait-on http://localhost:5173 && electron .",
    "build": "npm run typecheck && npm run build:vite && npm run build:electron && node scripts/build.js",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "check": "npm run typecheck && npm run lint",
    "preview": "vite preview",
    "setup-bins": "node scripts/download-bins.js",
    "setup-bins:force": "node scripts/download-bins.js --force"
  },
  "build": {
    "appId": "com.tenslor.monstera-pdf-editor",
    "productName": "Monstera PDF Editor",
    "copyright": "© 2026 Tenslor Inc.",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "assets/bin/**",
      "node_modules/koffi/**"
    ],
    "extraResources": [
      {
        "from": "assets/bin",
        "to": "app/assets/bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF Document",
        "role": "Editor",
        "icon": "assets/icons/icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Monstera PDF Editor",
      "uninstallDisplayName": "Monstera PDF Editor (Tenslor Inc.)",
      "license": "build/license.txt",
      "installerHeaderIcon": "assets/icons/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.9.5",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.4.3",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@huggingface/transformers": "^4.2.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@signpdf/placeholder-pdf-lib": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "bwip-js": "^4.11.1",
    "dictionary-en": "^4.0.0",
    "docx": "^9.7.1",
    "dropbox": "^10.34.0",
    "exceljs": "^4.4.0",
    "googleapis": "^173.0.0",
    "jszip": "^3.10.1",
    "koffi": "^3.0.2",
    "lucide-react": "^1.17.0",
    "mailparser": "^3.9.9",
    "mammoth": "^1.12.0",
    "mupdf": "^1.27.0",
    "node-forge": "^1.4.0",
    "nspell": "^2.1.5",
    "pdf-lib": "npm:@cantoo/pdf-lib@^2.7.1",
    "pdfjs-dist": "^6.0.227",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.14",
    "zxing-wasm": "^3.1.0"
  }
}
