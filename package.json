{
  "name": "monstera-pdf-editor",
  "version": "0.1.0",
  "description": "Personal-use desktop PDF editor",
  "main": "dist-electron/main/main.js",
  "author": "Personal Use",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:vite && npm run build:electron && electron-builder",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "setup-bins": "node scripts/download-bins.js",
    "setup-bins:force": "node scripts/download-bins.js --force"
  },
  "build": {
    "appId": "com.personal.monstera-pdf-editor",
    "productName": "Monstera PDF Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "assets/bin/**",
      "node_modules/koffi/**"
    ],
    "extraResources": [
      {
        "from": "assets/bin",
        "to": "app/assets/bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@signpdf/placeholder-pdf-lib": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "@types/qrcode": "^1.5.6",
    "bwip-js": "^4.11.1",
    "dictionary-en": "^4.0.0",
    "docx": "^9.7.1",
    "dropbox": "^10.34.0",
    "googleapis": "^173.0.0",
    "koffi": "^3.0.2",
    "mailparser": "^3.9.9",
    "mammoth": "^1.12.0",
    "mupdf": "^0.3.0",
    "node-forge": "^1.4.0",
    "nspell": "^2.1.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tesseract.js": "^5.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14",
    "zxing-wasm": "^3.1.0"
  }
}
